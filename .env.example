# Database
DATABASE_URL=postgresql://dpin:dpin_secret@localhost:5432/dpin?schema=public

# API
PORT=3001
NODE_ENV=development
JWT_SECRET=
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
CORS_ORIGIN=http://localhost:3000
NODE_HEARTBEAT_GRACE_SECONDS=120

# Hub
SCHEDULER_INTERVAL_MS=10000
STALE_JOB_TIMEOUT_MS=120000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/v1

# Validator defaults (seeded node)
HUB_API_URL=http://localhost:3001/v1
NODE_ID=validator-us-east-dev
NODE_REGION=us-east-1
NODE_API_KEY=
NODE_HMAC_SECRET=
POLL_INTERVAL_SECONDS=5
HEARTBEAT_INTERVAL_SECONDS=30
CHECK_TIMEOUT_SECONDS=10

# Additional seeded nodes


# Terraform / cloud
AWS_REGION=us-east-1
HEALTH_CHECK_DOMAIN=api.example.com
