{
  "name": "db",
  "module": "index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:seed": "bun run prisma/seed.ts",
    "check-types": "tsc --noEmit"
  },
  "private": true,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "prisma": "^6.5.0"
  }
}
