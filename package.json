{
  "name": "dpin-uptime",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:hub": "bun run --cwd apps/hub dev",
    "dev:validator": "bun run --cwd apps/validator dev",
    "dev:validator:go": "cd apps/validator-go && go run ./cmd/validator",
    "dev:frontend": "bun run --cwd apps/frontend dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:seed": "bun run --cwd packages/db db:seed",
    "validator:go:build": "cd apps/validator-go && go build ./cmd/validator",
    "validator:go:test": "cd apps/validator-go && go test ./...",
    "infra:plan:dev": "terraform -chdir=infra/terraform/environments/dev plan",
    "infra:plan:prod": "terraform -chdir=infra/terraform/environments/prod plan",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.2.5"
}
